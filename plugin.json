{
  "spec": "soksak-spec-plugin@0.0.1",
  "id": "soksak-plugin-terminal-xterm",
  "name": {
    "ko": "\ud130\ubbf8\ub110",
    "en": "Terminal"
  },
  "version": "0.0.1",
  "renamedFrom": "soksak-plugin-terminal",
  "description": {
    "ko": "xterm.js \ud130\ubbf8\ub110 \ud328\ub110 \u2014 \ucf54\uc5b4 PTY \ub97c \uc9c1\uc811 \uad6c\ub3d9.",
    "en": "xterm.js terminal pane driven by core PTY."
  },
  "entry": "main.js",
  "implements": [
    {
      "id": "soksak-spec-plugin-terminal",
      "version": "0.0.1"
    }
  ],
  "sidecars": [
    {
      "name": "terminal-alacritty",
      "interface": {
        "id": "soksak-spec-sidecar-terminal",
        "range": "0.0.1"
      }
    }
  ],
  "permissions": [
    "ui",
    "commands",
    "programs",
    "process",
    "pty",
    "data",
    "terminal",
    "terminal:read"
  ],
  "configuration": [
    {
      "key": "shell",
      "type": "string",
      "default": "",
      "title": {
        "ko": "\uc178",
        "en": "Shell"
      }
    },
    {
      "key": "xtermRenderer",
      "type": "enum",
      "enum": [
        "dom",
        "webgl"
      ],
      "enumLabels": [
        {
          "ko": "DOM",
          "en": "DOM"
        },
        {
          "ko": "WebGL (GPU)",
          "en": "WebGL (GPU)"
        }
      ],
      "default": "webgl",
      "title": {
        "ko": "\ud130\ubbf8\ub110 \ub80c\ub354\ub7ec",
        "en": "Terminal renderer"
      }
    },
    {
      "key": "fontFamily",
      "type": "string",
      "default": "\"JetBrains Mono\", \"SF Mono\", \"Cascadia Code\", Menlo, Consolas, \"Courier New\", monospace",
      "title": {
        "ko": "\uae00\uaf34",
        "en": "Font family"
      }
    },
    {
      "key": "fontSize",
      "type": "number",
      "default": 13,
      "min": 8,
      "max": 32,
      "title": {
        "ko": "\uae00\uaf34 \ud06c\uae30",
        "en": "Font size"
      }
    },
    {
      "key": "scrollback",
      "type": "number",
      "default": 10000,
      "min": 0,
      "max": 200000,
      "title": {
        "ko": "\uc2a4\ud06c\ub864\ubc31 \uc904 \uc218",
        "en": "Scrollback lines"
      }
    },
    {
      "key": "cursorBlink",
      "type": "boolean",
      "default": true,
      "title": {
        "ko": "\ucee4\uc11c \uae5c\ube61\uc784",
        "en": "Cursor blink"
      }
    },
    {
      "key": "cursorStyle",
      "type": "enum",
      "enum": [
        "block",
        "underline",
        "bar"
      ],
      "enumLabels": [
        {
          "ko": "\ube14\ub85d",
          "en": "Block"
        },
        {
          "ko": "\ubc11\uc904",
          "en": "Underline"
        },
        {
          "ko": "\ub9c9\ub300",
          "en": "Bar"
        }
      ],
      "default": "block",
      "title": {
        "ko": "\ucee4\uc11c \ubaa8\uc591",
        "en": "Cursor style"
      }
    }
  ],
  "contributes": {
    "programs": [
      {
        "id": "terminal-xterm",
        "title": {
          "ko": "\ud130\ubbf8\ub110",
          "en": "Terminal"
        },
        "kind": "view",
        "view": "content"
      }
    ],
    "views": [
      {
        "id": "content",
        "title": {
          "ko": "\ud130\ubbf8\ub110",
          "en": "Terminal"
        },
        "icon": ">_",
        "placements": [
          "content"
        ],
        "defaultPlacement": "content",
        "status": [
          "connecting",
          "error"
        ]
      }
    ],
    "commands": [
      {
        "name": "ping",
        "title": {
          "ko": "\ud50c\ub7ec\uadf8\uc778 \uc801\uc7ac/\ubc84\uc804 \ud655\uc778(E2E)",
          "en": "Ping (load/version check)"
        }
      },
      {
        "name": "send",
        "title": {
          "ko": "\ud14d\uc2a4\ud2b8 \uc804\uc1a1",
          "en": "Send Text"
        }
      },
      {
        "name": "clear",
        "title": {
          "ko": "\uc9c0\uc6b0\uae30",
          "en": "Clear"
        }
      },
      {
        "name": "resume",
        "title": {
          "ko": "\uc138\uc158 \uc774\uc5b4\uac00\uae30",
          "en": "Resume Session"
        }
      },
      {
        "name": "perf.stats",
        "title": {
          "ko": "\uc131\ub2a5 \uce74\uc6b4\ud130 \uc77d\uae30",
          "en": "Read Performance Counters"
        }
      },
      {
        "name": "perf.echo",
        "title": {
          "ko": "\uc785\ub825 \uc5d0\ucf54 \uc655\ubcf5 \uce21\uc815",
          "en": "Measure Input Echo Roundtrip"
        }
      }
    ],
    "nodes": [
      {
        "id": "terminal-xterm",
        "description": {
          "ko": "xterm.js \ud130\ubbf8\ub110 \ucee8\ud14c\uc774\ub108",
          "en": "xterm.js terminal container"
        }
      }
    ]
  }
}
